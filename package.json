{
  "name": "react-native-nitro-keepalive-timer",
  "version": "0.1.5",
  "description": "Background-safe keepalive timers for React Native. Drop-in setTimeout/setInterval that keep firing when the screen is locked — built for LiveKit calls, audio sessions, and long-lived connections. Powered by Nitro Modules.",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "cpp",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "app.plugin.js",
    "nitro.json",
    "*.podspec",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "lint": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "lint-ci": "eslint \"**/*.{js,ts,tsx}\" -f @jamesacarr/github-actions",
    "typescript": "tsc",
    "prepare": "tsc",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\"",
    "check:specs": "bun run specs && git diff --exit-code -- nitrogen/generated"
  },
  "keywords": [
    "react-native",
    "nitro",
    "nitro-modules",
    "timer",
    "settimeout",
    "setinterval",
    "background",
    "background-timer",
    "keepalive",
    "keep-alive",
    "heartbeat",
    "livekit",
    "webrtc",
    "voip",
    "call",
    "audio",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfairley/react-native-nitro-keepalive-timer.git"
  },
  "author": "Michael Fairley",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mfairley/react-native-nitro-keepalive-timer/issues"
  },
  "homepage": "https://github.com/mfairley/react-native-nitro-keepalive-timer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "codegenConfig": {
    "name": "NitroKeepaliveTimerSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.margelo.nitro.nitrokeepalivetimer"
    }
  },
  "devDependencies": {
    "@react-native/eslint-config": "0.83.0",
    "@types/react": "~19.2.14",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nitrogen": "~0.35.6",
    "prettier": "^3.3.3",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "~0.35.6",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  }
}
