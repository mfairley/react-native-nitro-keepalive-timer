{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrokeepalivetimer"
  ],
  "ios": {
    "iosModuleName": "NitroKeepaliveTimer"
  },
  "android": {
    "androidNamespace": [
      "nitrokeepalivetimer"
    ],
    "androidCxxLibName": "NitroKeepaliveTimer"
  },
  "autolinking": {
    "Timer": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTimer"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTimer"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
